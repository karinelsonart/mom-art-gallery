from flask import Flask, render_template, request, redirect, url_for, flash
import os
import csv
from datetime import datetime
import uuid
import subprocess

# Paths
SITE_DIR = "/root/mom-art-gallery"
GALLERY_DIR = os.path.join(SITE_DIR, "static/gallery")
CSV_FILE = os.path.join(SITE_DIR, "assets/gallery.csv")
ALLOWED_EXTENSIONS = {"jpg", "jpeg", "png", "gif"}

app = Flask(__name__)
app.secret_key = "supersecretkey"

# Helpers
def allowed_file(filename):
    return "." in filename and filename.rsplit(".", 1)[1].lower() in ALLOWED_EXTENSIONS

def load_artworks():
    artworks = []
    if os.path.exists(CSV_FILE):
        with open(CSV_FILE, newline="", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            artworks = list(reader)
    return artworks

def rebuild_site():
    """Rebuild the Hugo site to reflect current CSV and images."""
    try:
        subprocess.run(["hugo", "-s", SITE_DIR, "-d", os.path.join(SITE_DIR, "public")], check=True)
        print("Hugo site rebuilt successfully.")
    except subprocess.CalledProcessError as e:
        print("Error rebuilding Hugo site:", e)

# Routes
@app.route("/", methods=["GET", "POST"])
def upload():
    if request.method == "POST":
        file = request.files.get("image")
        if not file or not allowed_file(file.filename):
            flash("Please upload a valid image file (jpg, png, gif).")
            return redirect(request.url)

        title = request.form.get("title", "").strip()
        date = request.form.get("date", "").strip()
        description = request.form.get("description", "").strip()
        category = request.form.get("category", "").strip()

        if not title:
            flash("Title is required.")
            return redirect(request.url)

        # Auto-generate filename
        ext = file.filename.rsplit(".", 1)[1].lower()
        filename = f"{datetime.now().strftime('%Y%m%d_%H%M%S')}_{uuid.uuid4().hex[:6]}.{ext}"
        filepath = os.path.join(GALLERY_DIR, filename)
        file.save(filepath)

        if not date:
            date = datetime.now().strftime("%Y-%m-%d")

        # Append to CSV
        csv_exists = os.path.exists(CSV_FILE)
        with open(CSV_FILE, "a", newline="", encoding="utf-8") as csvfile:
            writer = csv.writer(csvfile)
            if not csv_exists:
                writer.writerow(["filename","title","date","description","category"])
            writer.writerow([filename,title,date,description,category])

        rebuild_site()  # Rebuild Hugo after upload
        flash("Artwork uploaded successfully!")
        return redirect(request.url)

    return render_template("upload.html")

@app.route("/gallery")
def gallery():
    artworks = load_artworks()
    return render_template("gallery.html", artworks=artworks)

@app.route("/edit/<filename>", methods=["GET", "POST"])
def edit(filename):
    artworks = load_artworks()
    row_to_edit = next((r for r in artworks if r["filename"] == filename), None)
    if not row_to_edit:
        flash("Artwork not found")
        return redirect(url_for("gallery"))

    if request.method == "POST":
        # Update metadata
        row_to_edit["title"] = request.form.get("title", "").strip()
        row_to_edit["date"] = request.form.get("date", "").strip()
        row_to_edit["description"] = request.form.get("description", "").strip()
        row_to_edit["category"] = request.form.get("category", "").strip()

        # Handle optional new image
        file = request.files.get("image")
        if file and allowed_file(file.filename):
            # Remove old image
            old_path = os.path.join(GALLERY_DIR, row_to_edit["filename"])
            if os.path.exists(old_path):
                os.remove(old_path)

            # Save new image
            ext = file.filename.rsplit(".", 1)[1].lower()
            new_filename = f"{datetime.now().strftime('%Y%m%d_%H%M%S')}_{uuid.uuid4().hex[:6]}.{ext}"
            file.save(os.path.join(GALLERY_DIR, new_filename))
            row_to_edit["filename"] = new_filename

        # Write CSV back
        with open(CSV_FILE, "w", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=["filename","title","date","description","category"])
            writer.writeheader()
            writer.writerows(artworks)

        rebuild_site()  # Rebuild Hugo after edit
        flash("Artwork updated!")
        return redirect(url_for("gallery"))

    return render_template("edit.html", artwork=row_to_edit)

@app.route("/delete/<filename>", methods=["POST"])
def delete(filename):
    artworks = load_artworks()
    row_to_delete = next((r for r in artworks if r["filename"] == filename), None)
    if not row_to_delete:
        flash("Artwork not found")
        return redirect(url_for("gallery"))

    # Remove image file
    img_path = os.path.join(GALLERY_DIR, filename)
    if os.path.exists(img_path):
        os.remove(img_path)

    # Remove from CSV
    artworks = [r for r in artworks if r["filename"] != filename]
    with open(CSV_FILE, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=["filename","title","date","description","category"])
        writer.writeheader()
        writer.writerows(artworks)

    rebuild_site()  # Rebuild Hugo after delete
    flash("Artwork deleted successfully!")
    return redirect(url_for("gallery"))

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000, debug=True)
